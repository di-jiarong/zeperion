# 复制为 config.env 后使用

# ===== 通用 =====
REQUIREMENT_FILE="./requirement_template.txt"
STATE_DIR="./state"
PROMPT_DIR="./prompts"
LOG_DIR="./state/logs"

# ===== 单智能体 =====
SINGLE_MODEL="fast-model"
SINGLE_MAX_CYCLES=200
SINGLE_SLEEP_SECONDS=2

# 旧版兼容（不推荐，存在命令注入风险）
# SINGLE_AGENT_CALL_TEMPLATE='claude --model "$MODEL" --print < "$PROMPT_FILE" > "$OUTPUT_FILE" 2>> "$LOG_FILE"'

# ===== 多智能体 =====
MASTER_MODEL="balanced-model"
PLANNER_MODEL="quality-model"
DEVELOPER_MODEL="fast-model"
TESTER_MODEL="quality-model"

MAX_ROUNDS=50
MAX_FIX_ATTEMPTS=3
ROUND_SLEEP_SECONDS=2
ROLE_CALL_MAX_RETRIES=2
ROLE_RETRY_SLEEP_SECONDS=2

# true: 某角色失败后跳过本轮继续下一轮；false: 直接停止，等待人工处理
CONTINUE_ON_ROLE_ERROR=false

# LLM CLI 配置（结构化，避免 eval 安全风险）
# 命令行工具路径
LLM_CLI_COMMAND="claude"
# 固定参数（空格分隔）
LLM_CLI_ARGS="--print"
# 是否使用 stdin 传递 prompt（true/false）
LLM_USE_STDIN=true
# 是否支持 --model 参数（true/false）
LLM_SUPPORT_MODEL_FLAG=true

# 旧版兼容（不推荐，存在命令注入风险）
# MULTI_AGENT_CALL_TEMPLATE='claude --model "$MODEL" --print < "$PROMPT_FILE" > "$OUTPUT_FILE" 2>> "$LOG_FILE"'

# ===== PR 交付管线 =====
# GitHub 仓库（如 "topsun-bot/topsun_dimos"）
GITHUB_REPO=""
# GitHub Token（需要有 contents:write + pull-requests:write 权限）
GITHUB_TOKEN=""
# 本地分支名（默认取当前 git 分支）
PR_BRANCH=""
# 目标分支（PR 合并到哪）
PR_TARGET_BRANCH="dev"
# 等待 Codex 审查的最大分钟数
CODEX_POLL_MINUTES=30
